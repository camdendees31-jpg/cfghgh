{
  "$schema": "https://raw.githubusercontent.com/QuestPackageManager/QPM.Package/refs/heads/main/qpm.schema.json",
  "info": {
    "name": "YourModName",
    "id": "your-mod-id",
    "version": "1.0.0",
    "url": null,
    "additionalData": {}
  },
  "sharedDir": "shared",
  "dependenciesDir": "extern",
  "dependencies": [
    {
      "id": "scotland2",
      "versionRange": "^0.1.6",
      "additionalData": {
        "includeQmod": false,
        "private": true
      }
    },
    {
      "id": "beatsaber-hook",
      "versionRange": "^6.4.2",
      "additionalData": {}
    }
  ],
  "workspace": {
    "ndk": "27",
    "scripts": {
      "build": ["cmake -B build -G Ninja && cmake --build ./build --config RelWithDebInfo"],
      "qmod": ["python3 buildQMOD.py your-mod-id"]
    }
  }
}
